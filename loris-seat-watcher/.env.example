# Path to Playwright storageState JSON (login once via: npm run save-session)
LORIS_STORAGE_STATE=./storageState.json

# SMTP for student notifications (example: Gmail app password — prefer a transactional provider in production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="LORIS watcher <you@example.com>"

# Optional: email you when the saved session looks expired / login page appears
OPERATOR_EMAIL=you@example.com

# Set to 1 to scrape LORIS and print "would email" to the console (no SMTP required)
# Or run: npm run check -- --dry-run
# SKIP_EMAIL=1
